{
  "github": {
    "silent": true,
    "enabled": true
  },
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["syd1"],
  "crons": [
    {
      "path": "/api/cron/refresh-tokens",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/cron/sync-analytics",
      "schedule": "0 1 * * *"
    }
  ]
}
