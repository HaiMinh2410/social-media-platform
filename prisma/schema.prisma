// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id               String            @id @db.Uuid
  fullName         String?           @map("full_name")
  avatarUrl        String?           @map("avatar_url")
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at")
  platformAccounts PlatformAccount[]

  @@map("profiles")
}

model PlatformAccount {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId        String         @map("profile_id") @db.Uuid
  profile          Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  platform         String         @db.VarChar(10)
  platformUserId   String         @map("platform_user_id")
  platformUserName String         @map("platform_user_name")
  createdAt        DateTime       @default(now()) @map("created_at")
  metaTokens       MetaToken[]
  conversations    Conversation[]

  botConfiguration BotConfiguration?
  analyticsSnapshots AnalyticsSnapshot[]
  posts              Post[]

  @@unique([platform, platformUserId])
  @@map("platform_accounts")
}

model AnalyticsSnapshot {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId       String          @map("account_id") @db.Uuid
  platformAccount PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date            DateTime        @db.Date
  reach           Int             @default(0)
  impressions     Int             @default(0)
  engagement      Int             @default(0)
  followers       Int             @default(0)
  createdAt       DateTime        @default(now()) @map("created_at")

  @@unique([accountId, date])
  @@map("analytics_snapshots")
}

model BotConfiguration {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId           String          @unique @map("account_id") @db.Uuid
  platformAccount     PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  isActive            Boolean         @default(false) @map("is_active")
  triggerLabels       String[]        @map("trigger_labels")
  confidenceThreshold Float           @default(0.75) @map("confidence_threshold")
  autoSend            Boolean         @default(false) @map("auto_send")
  updatedAt           DateTime        @default(now()) @updatedAt @map("updated_at")

  @@map("bot_configurations")
}

model MetaToken {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId              String          @map("account_id") @db.Uuid
  platformAccount        PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  encryptedAccessToken   String          @map("encrypted_access_token")
  encryptedRefreshToken String?         @map("encrypted_refresh_token")
  expiresAt              DateTime        @map("expires_at")
  updatedAt              DateTime        @default(now()) @updatedAt @map("updated_at")

  @@map("meta_tokens")
}

model Conversation {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId              String          @map("account_id") @db.Uuid
  platformAccount        PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platformConversationId String          @map("platform_conversation_id")
  lastMessageAt          DateTime        @default(now()) @map("last_message_at")
  messages               Message[]

  @@unique([accountId, platformConversationId])
  @@map("conversations")
}

model Message {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId     String         @map("conversation_id") @db.Uuid
  conversation       Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId           String         @map("sender_id")
  content            String         @db.Text
  platformMessageId  String         @unique @map("platform_message_id")
  isRead             Boolean        @default(false) @map("is_read")
  createdAt          DateTime       @default(now()) @map("created_at")
  aiReplyLogs        AIReplyLog[]

  @@map("messages")
}

model AIReplyLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId   String   @map("message_id") @db.Uuid
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  prompt      String   @db.Text
  response    String   @db.Text
  model       String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("ai_reply_logs")
}

model Post {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId        String          @map("account_id") @db.Uuid
  platformAccount  PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  content          String?         @db.Text
  mediaUrls        String[]        @map("media_urls")
  status           String          @default("draft") // draft, scheduled, published, error
  scheduledAt      DateTime?       @map("scheduled_at")
  platformPostId   String?         @map("platform_post_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at")

  @@map("posts")
}
